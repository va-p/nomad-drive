{
  "name": "nomad-drive",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "android": "expo run:android",
    "ios": "expo run:ios",
    "start": "npx expo start --dev-client",
    "format": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix && prettier \"**/*.{js,jsx,ts,tsx,json}\" --write",
    "web": "expo start --web",
    "clean-android": "cd android && ./gradlew clean",
    "prebuild-android": "npx expo prebuild --platform android --no-install",
    "build-android-dev": "cd android && ./gradlew assembleDebug",
    "build-android-release": "cd android && ./gradlew bundleRelease",
    "build-android-dev-eas": "eas build --profile development --platform android",
    "build-android-release-eas": "eas build --profile production --platform android",
    "clean-ios": "cd ios && xcodebuild clean -workspace smartfinances.xcworkspace -scheme smartfinances",
    "prebuild-ios": "npx expo prebuild --platform ios --no-install",
    "build-ios-dev": "cd ios && xcodebuild build -workspace smartfinances.xcworkspace -scheme smartfinances -configuration Debug -sdk iphonesimulator -derivedDataPath build",
    "build-ios-release": "cd ios && xcodebuild archive -workspace smartfinances.xcworkspace -scheme smartfinances -configuration Release -sdk iphoneos -archivePath build/smartfinances.xcarchive",
    "build-ios-dev-eas": "eas build --profile development --platform ios",
    "build-ios-release-eas": "eas build --profile production --platform ios",
    "bundle-analyze": "EXPO_UNSTABLE_ATLAS=true npx expo start --dev-client",
    "test": "jest",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\" && prettier -c \"**/*.{js,jsx,ts,tsx,json}\""
  },
  "dependencies": {
    "@clerk/clerk-expo": "^2.19.31",
    "@expo-google-fonts/poppins": "^0.4.1",
    "@expo/vector-icons": "^15.0.2",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-firebase/analytics": "^23.8.8",
    "@react-native-firebase/app": "^23.8.8",
    "@react-native-firebase/crashlytics": "^23.8.8",
    "@react-navigation/native": "^7.1.6",
    "axios": "^1.13.6",
    "babel-plugin-module-resolver": "^5.0.2",
    "expo": "^54.0.0",
    "expo-auth-session": "~7.0.10",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.9",
    "expo-font": "~14.0.11",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.8",
    "expo-local-authentication": "~17.0.8",
    "expo-router": "~6.0.10",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.8",
    "expo-system-ui": "~6.0.7",
    "expo-web-browser": "~15.0.7",
    "phosphor-react-native": "^3.0.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.71.2",
    "react-native": "0.81.5",
    "react-native-device-info": "^15.0.2",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-mmkv": "^4.2.0",
    "react-native-nitro-modules": "^0.35.2",
    "react-native-onesignal": "^5.3.4",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-svg-transformer": "^1.5.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "styled-components": "^6.3.11",
    "zod": "^4.3.6",
    "zustand": "^4.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~19.1.10",
    "@types/styled-components": "^5.1.36",
    "@types/styled-components-react-native": "^5.2.5",
    "eslint": "^9.25.1",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.2",
    "prettier": "^3.2.5",
    "typescript": "~5.9.2"
  },
  "packageManager": "yarn@4.13.0",
  "private": true
}
